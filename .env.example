# Скопируйте в .env:  cp .env.example .env
# Не коммитьте .env — он в .gitignore.

# RPC Sepolia (пример: Alchemy / Infura)
SEPOLIA_RPC_URL=

# Etherscan API key — для forge verify / make deploy-sepolia
ETHERSCAN_API_KEY=

# Опционально: только для локальных команд в терминале.
# Для деплоя Makefile использует keystore: cast wallet import my-sepolia --private-key <KEY>
# PRIVATE_KEY=
